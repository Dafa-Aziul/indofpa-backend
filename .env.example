###################################
# ========= APP CONFIG ============
###################################

NODE_ENV=development
PORT=5000

# URL backend (API)
APP_PUBLIC_URL=http://localhost:5000

# URL frontend (React / Next.js)
CLIENT_URL=http://localhost:3000



###################################
# ========= DATABASE ==============
# Laravel-style variables
###################################

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=indofpa
DB_USERNAME=root
DB_PASSWORD=

# Optional (jika pakai ORM / Prisma / Sequelize)
DATABASE_URL="mysql://root:@localhost:3306/indofpa"



###################################
# ========= AUTH / JWT ============
###################################

# Access token secret
JWT_ACCESS_SECRET=your_access_secret_here

# Refresh token secret
JWT_REFRESH_SECRET=your_refresh_secret_here

# Optional (issuer token)
JWT_ISSUER=your_app_name

# Optional expiry (jika backend support)
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d



###################################
# ========= COOKIE CONFIG =========
###################################

# Development = false
# Production   = true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax



###################################
# ========== OPTIONAL =============
###################################

UPLOAD_DRIVER=local

# EMAIL_HOST=
# EMAIL_USER=
# EMAIL_PASS=