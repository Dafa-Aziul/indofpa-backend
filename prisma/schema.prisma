// =====================================
// Prisma 7 Compatible Schema (Final)
// =====================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ======================
// ENUMS
// ======================

enum UsiaKategori {
  USIA_18_24   @map("18-24")
  USIA_25_34   @map("25-34")
  USIA_35_44   @map("35-44")
  USIA_45_54   @map("45-54")
  USIA_55_64   @map("55-64")
  USIA_65_PLUS @map("65+")
}

enum StatusKuesioner {
  Draft
  Publish
  Arsip
}

enum JenisKelamin {
  L
  P
}

enum TingkatPendidikan {
  TidakTamatSD @map("Tidak tamat SD")
  SD
  SMP
  SMA
  Diploma
  S1
  S2
  S3
}

enum Agama {
  Islam
  KristenProtestan @map("Kristen Protestan")
  Katolik
  Hindu
  Buddha
  Konghucu
  Kepercayaan
}

// ======================
// MODELS
// ======================

model User {
  userId    Int      @id @default(autoincrement())
  nama      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs         LogAktivitas[]
  kuesioner    Kuesioner[]    @relation("PembuatKuesioner")
  refreshToken RefreshToken[]
}

model LogAktivitas {
  logId      Int      @id @default(autoincrement())
  userId     Int
  aksi       String
  keterangan String?
  waktu      DateTime @default(now())

  user User @relation(fields: [userId], references: [userId])
}

model Kuesioner {
  kuesionerId   Int             @id @default(autoincrement())
  pembuatId     Int
  kategoriId    Int
  judul         String
  tujuan        String?
  manfaat       String?
  estimasiMenit Int?
  status        StatusKuesioner @default(Draft)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  pembuat    User                  @relation("PembuatKuesioner", fields: [pembuatId], references: [userId])
  kategori   Kategori              @relation("KategoriKuesioner", fields: [kategoriId], references: [kategoriId])
  indikator  Indikator[]
  responden  RespondenProfile[]
  score      RespondenScore[]
  distribusi DistribusiKuesioner[]

  @@index([pembuatId])
}

model Indikator {
  indikatorId Int      @id @default(autoincrement())
  kuesionerId Int
  nama        String
  kode        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kuesioner  Kuesioner        @relation(fields: [kuesionerId], references: [kuesionerId])
  pertanyaan Pertanyaan[]
  score      RespondenScore[]

  @@index([kuesionerId])
}

model Pertanyaan {
  pertanyaanId   Int      @id @default(autoincrement())
  indikatorId    Int
  teksPertanyaan String
  urutan         Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  indikator Indikator @relation(fields: [indikatorId], references: [indikatorId])
  jawaban   Jawaban[]

  @@index([indikatorId])
}

model RespondenProfile {
  respondenId       Int               @id @default(autoincrement())
  kuesionerId       Int
  nama              String?
  email             String?
  usiaKategori      UsiaKategori
  jenisKelamin      JenisKelamin
  tingkatPendidikan TingkatPendidikan
  agama             Agama
  pekerjaan         String?

  waktuMulai   DateTime?
  waktuSelesai DateTime?
  createdAt    DateTime  @default(now())

  kuesioner Kuesioner        @relation(fields: [kuesionerId], references: [kuesionerId])
  jawaban   Jawaban[]
  score     RespondenScore[]

  @@unique([email, kuesionerId])
  @@index([kuesionerId])
}

model Jawaban {
  jawabanId    Int @id @default(autoincrement())
  respondenId  Int
  pertanyaanId Int
  nilai        Int

  responden  RespondenProfile @relation(fields: [respondenId], references: [respondenId])
  pertanyaan Pertanyaan       @relation(fields: [pertanyaanId], references: [pertanyaanId])

  @@unique([respondenId, pertanyaanId])
  @@index([respondenId])
  @@index([pertanyaanId])
}

model RespondenScore {
  respondenScoreId Int      @id @default(autoincrement())
  kuesionerId      Int
  respondenId      Int
  indikatorId      Int
  scoreRaw         Float
  scoreNormalized  Float?
  createdAt        DateTime @default(now())

  kuesioner Kuesioner        @relation(fields: [kuesionerId], references: [kuesionerId])
  responden RespondenProfile @relation(fields: [respondenId], references: [respondenId])
  indikator Indikator        @relation(fields: [indikatorId], references: [indikatorId])

  @@index([kuesionerId])
  @@index([respondenId])
  @@index([indikatorId])
}

model DistribusiKuesioner {
  distribusiId   Int       @id @default(autoincrement())
  kuesionerId    Int
  kodeAkses      String
  urlLink        String
  tanggalMulai   DateTime?
  tanggalSelesai DateTime?
  catatan        String?

  kuesioner Kuesioner @relation(fields: [kuesionerId], references: [kuesionerId])

  @@index([kuesionerId])
}

model RefreshToken {
  refreshTokenId Int      @id @default(autoincrement())
  token          String   @unique
  userId         Int
  user           User     @relation(fields: [userId], references: [userId])
  expiredAt      DateTime
  createdAt      DateTime @default(now())
}

model Kategori {
  kategoriId Int      @id @default(autoincrement())
  nama       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  kuesioner Kuesioner[] @relation("KategoriKuesioner")
}
